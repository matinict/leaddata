{
  "channel": "360Debate",
  "channel_lower": "360debate",
  "tts_speech_rate": "+25%",
  "video_speed": 1.2,
  "use_label_mappings": true,
  "keep_shorts_backup": false,
  "shorts_max_seconds": 100,
  "intro_slug": "One of the biggest debates in Ai tech right now",
  "debate_definition_enabled": false,
  "debate_mini_enabled": true,
  "debate_max_chars": 9000,
  "intro_enabled": true,
  "debate_video_enabled": true,
  "debate_3d_enabled": true,
  "debate_secs_per_line": 3.5,
  "debate_background_enabled": false, 
  "debate_bg_opacity": 150,
  "debate_background_prompt": "futuristic digital debate arena, dark navy deep purple, abstract geometric circuit patterns, soft volumetric light beams, blurred bokeh background, cinematic, no text, no faces",
  "image_gen_backend": "auto",
  "debate_merge_enabled": false,
  "piper_voices": {
    "propose": {
      "model": "models/joe_medium.onnx",
      "speed": 1.05,
      "pitch": 0.5
    },
    "oppose": {
      "model": "models/alba_medium.onnx",
      "speed": 1.05,
      "pitch": -0.5
    },
    "decide": {
      "model": "models/en_GB-scott-medium.onnx",
      "speed": 1,
      "pitch": 0
    }
  },
  "edge_tts_voices": {
    "propose": {
      "edge_voice": "en-US-RogerNeural"
    },
    "oppose": {
      "edge_voice": "en-US-AriaNeural"
    },
    "judge_f": {
      "edge_voice": "en-CA-ClaraNeural"
    },
    "judge_m": {
      "edge_voice": "en-CA-LiamNeural"
    },
    "decide": {
      "edge_voice": "en-US-ChristopherNeural"
    }
  },
  "debate_3d_clips_file": "input/clips3d.json",
  "debate_3d_score_file": "input/score3d.json",
  "debate_3d_score": {
    "enabled": false,
    "score_voice": "decide",
    "score_audio_enabled": true,
    "score_bgm_enabled": true,
    "show_title": false,
    "hd_only": true,
    "duration": 8.0,
    "max_args": {
      "Shorts": 2,
      "HD": 3
    },
    "teaser_duration": 2.5,
    "teaser_after_intro": false,
    "subtitle": "@360Debate",
    "judges_enabled": true
  },
  "dynamic_scoreboards_enabled": [
    "HD"
  ]
}
